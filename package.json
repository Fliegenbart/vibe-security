{
  "name": "vibesafe",
  "version": "1.0.0",
  "description": "Security scanner for AI-generated (vibe-coded) projects",
  "type": "module",
  "bin": {
    "vibesafe": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "start": "node dist/cli.js",
    "web": "node dist/web/server.js"
  },
  "keywords": [
    "security",
    "scanner",
    "vibe-coding",
    "ai",
    "vulnerability"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.2",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
